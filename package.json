{
  "name": "seams-cli",
  "version": "1.0.0-beta",
  "type": "module",
  "description": "Local-first markdown editor",
  "bin": {
    "seams": "./bin/seams.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "web-dist/"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "SEAMS_DEV=1 tsx watch src/cli.ts . --no-open",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "pnpm build:server && pnpm build:web",
    "build:server": "tsup src/cli.ts src/server.ts --format esm --dts --out-dir dist --clean",
    "build:web": "vite build --config web/vite.config.ts",
    "test": "node --import tsx --test web/src/lib/**/*.test.ts",
    "start": "node bin/seams.mjs .",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.1",
    "@fastify/websocket": "^11.0.2",
    "cac": "^6.7.14",
    "chokidar": "^4.0.3",
    "fastify": "^5.2.1",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@blocknote/core": "^0.47.3",
    "@blocknote/mantine": "^0.47.3",
    "@blocknote/react": "^0.47.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/vite": "^4.0.14",
    "@types/node": "^22.13.9",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "clsx": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.6.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.0.14",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "zustand": "^5.0.3"
  }
}
